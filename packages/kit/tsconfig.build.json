{
  "compilerOptions": {
    "target": "esnext",
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "baseUrl": ".",
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@magic/kit/*": ["./src/*"]
    },
    "strict": true,
    "declaration": false,
    "emitDeclarationOnly": false,
    "noEmit": false,
    "outDir": ".",
    "removeComments": false,
    "sourceMap": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["vite/client"],
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "lib"]
}
